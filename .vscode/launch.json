{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "여행 플래너 (브라우저 열기)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Local:.+(https?://\\S+)",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      },
      "console": "integratedTerminal"
    }
  ]
}
